# Allow documentation images if they are intentionally added later
!docs/**/*.png
!docs/**/*.PNG
!docs/**/*.jpg
!docs/**/*.JPG
!docs/**/*.jpeg
!docs/**/*.JPEG
!docs/**/*.webp
!docs/**/*.WEBP

# Samples folder should contain only safe text/readme examples by default
samples/**
